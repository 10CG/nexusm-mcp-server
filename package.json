{
  "name": "@nexusm/mcp-server",
  "version": "0.1.2",
  "description": "Nexusm MCP Server — generic MCP server exposing Nexusm core capabilities to MCP clients via stdio + Streamable HTTP transports.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "nexusm-mcp-server": "./dist/index.js"
  },
  "files": [
    "dist/**",
    "README.md",
    "RUNBOOK.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/10CG/nexusm-mcp-server.git"
  },
  "homepage": "https://github.com/10CG/nexusm-mcp-server#readme",
  "bugs": {
    "url": "https://forgejo.10cg.pub/10CG/nexusm-mcp-server/issues"
  },
  "scripts": {
    "build": "tsc && chmod +x dist/index.js",
    "type-check": "tsc -p tsconfig.typecheck.json",
    "test": "vitest run",
    "test:unit": "vitest run --config vitest.unit.config.ts",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "lint": "eslint src/ tests/ && prettier --check src/ tests/"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@nexusm/sdk": "^5.0.0",
    "prom-client": "^15.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0",
    "eslint": "^9.36.0",
    "@eslint/js": "^9.36.0",
    "typescript-eslint": "^8.60.0",
    "globals": "^15.0.0",
    "prettier": "^3.2.0"
  }
}
